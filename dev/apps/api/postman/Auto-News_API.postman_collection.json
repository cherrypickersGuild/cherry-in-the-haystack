{
  "info": {
    "name": "Auto-News API",
    "description": "Auto-News AI-powered news aggregation API.\n\nBase URL: http://localhost:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/health",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "health"]
            },
            "description": "서버 상태 확인. status=ok이면 정상."
          }
        },
        {
          "name": "Scheduler Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/scheduler/status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "scheduler", "status"]
            },
            "description": "APScheduler 상태 및 등록된 잡 목록 확인.\n- running: 스케줄러 실행 여부\n- jobs: 등록된 잡 이름과 다음 실행 시간"
          }
        }
      ]
    },
    {
      "name": "Articles",
      "item": [
        {
          "name": "List Articles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/articles?page=1&size=10&sort_by=published_at&order=desc",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "articles"],
              "query": [
                { "key": "page", "value": "1", "description": "페이지 번호 (1부터)" },
                { "key": "size", "value": "10", "description": "페이지당 건수 (1~100)" },
                { "key": "sort_by", "value": "published_at", "description": "정렬 기준: published_at, created_at, relevant_score, title" },
                { "key": "order", "value": "desc", "description": "정렬 방향: asc, desc" }
              ]
            },
            "description": "전체 아티클 목록 조회 (페이징 지원)"
          }
        },
        {
          "name": "List Articles - Filter by Source",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/articles?source=RSS&page=1&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "articles"],
              "query": [
                { "key": "source", "value": "RSS", "description": "소스 필터: RSS, HackerNews, Dev.to, Substack" },
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "소스별 아티클 필터링.\n가능한 값: RSS, HackerNews, Dev.to, Substack"
          }
        },
        {
          "name": "List Articles - Filter by Date Range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/articles?from=2026-02-19&to=2026-02-20&page=1&size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "articles"],
              "query": [
                { "key": "from", "value": "2026-02-19", "description": "시작일 (YYYY-MM-DD)" },
                { "key": "to", "value": "2026-02-20", "description": "종료일 (YYYY-MM-DD)" },
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "날짜 범위로 아티클 필터링"
          }
        },
        {
          "name": "Search Articles (Full-Text)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/articles/search?q=AI agent&page=1&size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "articles", "search"],
              "query": [
                { "key": "q", "value": "AI agent", "description": "검색어 (최소 2자). PostgreSQL Full-Text Search + pg_trgm 사용" },
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "PostgreSQL Full-Text Search로 아티클 검색.\ntsvector + pg_trgm 인덱스 활용.\n결과에 rank 점수 포함."
          }
        },
        {
          "name": "Get Article by Hash",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/articles/2b2bb922352c380a5bc7c5b91755eeac",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "articles", "2b2bb922352c380a5bc7c5b91755eeac"]
            },
            "description": "article_hash로 단일 아티클 상세 조회.\ncontent, summary, insights 등 전체 필드 포함."
          }
        },
        {
          "name": "Article Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/articles/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "articles", "stats"]
            },
            "description": "아티클 통계 집계.\n- overview: 전체 건수, 소스 수, 피드 수, Notion 동기화 건수\n- by_source: 소스별 건수\n- by_category: 카테고리별 건수"
          }
        }
      ]
    },
    {
      "name": "Feeds",
      "item": [
        {
          "name": "List All Feeds",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/feeds",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feeds"]
            },
            "description": "전체 피드 설정 목록 조회 (활성/비활성 모두)"
          }
        },
        {
          "name": "List Enabled Feeds Only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/feeds?enabled_only=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feeds"],
              "query": [
                { "key": "enabled_only", "value": "true", "description": "활성 피드만 조회" }
              ]
            },
            "description": "활성화된 피드만 조회"
          }
        },
        {
          "name": "Get Feed by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/feeds/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feeds", "1"]
            },
            "description": "피드 ID로 단일 피드 설정 조회"
          }
        },
        {
          "name": "Create Feed",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hacker News RSS\",\n  \"url\": \"https://hnrss.org/frontpage\",\n  \"source_type\": \"rss\",\n  \"category\": \"insights\",\n  \"enabled\": true,\n  \"count\": 5,\n  \"config\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/feeds",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feeds"]
            },
            "description": "새 피드 추가.\n\nsource_type 옵션:\n- rss: RSS 피드\n- substack: Substack 뉴스레터\n- api_hackernews: HackerNews API\n- api_devto: Dev.to API\n\ncategory 옵션:\n- insights, business, practical, big_tech\n\nconfig: API 소스별 추가 설정 (JSON)\n- api_hackernews: {\"keywords\": [\"AI\", \"LLM\"]}\n- api_devto: {\"tags\": [\"ai\", \"llm\"]}"
          }
        },
        {
          "name": "Update Feed",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/feeds/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feeds", "1"]
            },
            "description": "피드 설정 수정.\n변경하려는 필드만 전송하면 됨.\n\n예시:\n- 비활성화: {\"enabled\": false}\n- 카테고리 변경: {\"category\": \"business\"}\n- 수집 건수 변경: {\"count\": 10}"
          }
        },
        {
          "name": "Delete Feed",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/feeds/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feeds", "1"]
            },
            "description": "피드 삭제 (되돌릴 수 없음)"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Job Runs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs?page=1&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "전체 잡 실행 이력 조회"
          }
        },
        {
          "name": "List Job Runs - Filter by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs?job_name=news_pulling&page=1&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"],
              "query": [
                { "key": "job_name", "value": "news_pulling", "description": "잡 이름 필터: news_pulling, sync_dist, collection_weekly, journal_daily, action" },
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "특정 잡의 실행 이력만 조회"
          }
        },
        {
          "name": "Get Latest Job Run",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/news_pulling/latest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "news_pulling", "latest"]
            },
            "description": "특정 잡의 최근 실행 결과.\n- status: running, success, failed\n- stats: 실행 통계 (pulled, deduped, pushed, pg_saved)\n- error_msg: 실패 시 에러 메시지"
          }
        },
        {
          "name": "Trigger Job - news_pulling",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/news_pulling/trigger",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "news_pulling", "trigger"]
            },
            "description": "news_pulling 파이프라인 수동 실행.\n백그라운드 스레드에서 실행되므로 즉시 응답.\n\n실행 흐름:\nPull → Dedup → Score → Filter → Summarize → Notion Push → PostgreSQL Save\n\n진행 상황은 'Get Latest Job Run'으로 확인."
          }
        },
        {
          "name": "Trigger Job - sync_dist",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/sync_dist/trigger",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "sync_dist", "trigger"]
            },
            "description": "Notion에서 Milvus로 임베딩 동기화 실행"
          }
        },
        {
          "name": "Trigger Job - collection_weekly",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/collection_weekly/trigger",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "collection_weekly", "trigger"]
            },
            "description": "주간 컬렉션 요약 생성 (토요일 자동 실행)"
          }
        }
      ]
    }
  ]
}
